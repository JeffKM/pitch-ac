# Supabase 프로젝트 URL (Supabase 대시보드 → Settings → API에서 확인)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/publishable 키 (공개 가능)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SportMonks API 토큰 (server-only, 절대 공개 금지)
SPORTMONKS_API_KEY=your-sportmonks-api-key

# Vercel Cron 인증 시크릿 (랜덤 문자열, 절대 공개 금지)
# 생성 방법: openssl rand -base64 32
CRON_SECRET=your-cron-secret

# Vercel 자동 주입 (로컬에서는 설정 불필요)
# VERCEL_URL=your-deployment.vercel.app
