{
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,mjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,mjs}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate": "npm run type-check && npm run lint && npm run format:check",
    "scrape:scoutlab": "tsx scripts/scraper/main.ts",
    "sync:news": "npx tsx scripts/sync-news/main.ts",
    "extract:action-lines": "tsx scripts/extract-action-lines.ts",
    "seed:fixtures": "curl -sf http://localhost:3000/api/debug/football-data/sync && curl -sf http://localhost:3000/api/cron/sync-teams",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mjs}": [
      "prettier --write"
    ]
  },
  "dependencies": {
